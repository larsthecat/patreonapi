# =========================================================================
# PATREON APP APPLICATION CREDENTIALS
# Obtain these values from: https://www.patreon.com/portal/registration
# =========================================================================

PATREON_CLIENT_ID=REPLACE_WITH_YOUR_PATREON_CLIENT_ID
PATREON_CLIENT_SECRET=REPLACE_WITH_YOUR_PATREON_CLIENT_SECRET

# =========================================================================
# ROUTING & SECURITY CONFIGURATIONS
# REDIRECT_URI must match exactly what you filled out in the Portal settings.
# =========================================================================

REDIRECT_URI=REPLACE_WITH_YOUR_CODESANDBOX_PREVIEW_URL/oauth/callback
SESSION_SECRET=REPLACE_WITH_A_LONG_RANDOM_SECRET_KEY_STRING

# =========================================================================
# MEMBERSHIP VERIFICATION SETTINGS
# The specific ID string of the tier you intend to grant premium access to.
# =========================================================================

REQUIRED_TIER_ID=REPLACE_WITH_YOUR_TARGET_TIER_ID
